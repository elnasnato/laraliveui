{
    "name": "elnasnato/laraliveui",
    "description": "LaraLiveUI - The official UI component library for Livewire applications.",
    "keywords": ["laraliveui", "laravel", "livewire", "components", "ui", "laralive"],
    "license": "MIT",
    "authors": [
        {
            "name": "elnasnato",
            "homepage": "https://github.com/elnasnato"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/elnasnato"
        },
        {
            "type": "paypal",
            "url": "https://paypal.me/CrunchyNatto"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "symfony/console": "^6.0|^7.0|^8.0",
        "livewire/livewire": "^3.7.4|^4.0",
        "laravel/prompts": "^0.1|^0.2|^0.3"
    },
    "autoload": {
        "psr-4": {
            "Laraliveui\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laraliveui\\LaraliveuiServiceProvider"
            ],
            "aliases": {
                "Laraliveui": "Laraliveui\\Laraliveui"
            }
        }
    }
}
